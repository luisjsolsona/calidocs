# ── Servidor ──────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de datos ─────────────────────────────────
DB_PATH=/app/data/calidocs.db

# ── Almacenamiento de archivos ────────────────────
DOCS_PATH=/app/data/docs

# ── JWT ───────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_64_bytes
JWT_EXPIRES_IN=8h

# ── Superadmin inicial (seed automático) ──────────
SEED_ADMIN_EMAIL=admin@calidocs.es
# ⚠ CAMBIA ESTA CONTRASEÑA ANTES DE ARRANCAR EN PRODUCCIÓN
SEED_ADMIN_PASSWORD=Admin1234!

# ── Claude API (Módulo 4) ─────────────────────────
ANTHROPIC_API_KEY=
# Modelo Claude a usar (por defecto claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# ── CORS (origen permitido) ───────────────────────
CORS_ORIGIN=http://localhost
