# ── Servidor ──────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de datos ─────────────────────────────────
DB_PATH=/app/data/calidocs.db

# ── Almacenamiento de archivos ────────────────────
DOCS_PATH=/app/data/docs

# ── JWT ───────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_64_bytes
JWT_EXPIRES_IN=8h

# ── Superadmin inicial (seed automático) ──────────
SEED_ADMIN_EMAIL=admin@calidocs.es
# ⚠ CAMBIA ESTA CONTRASEÑA ANTES DE ARRANCAR EN PRODUCCIÓN
SEED_ADMIN_PASSWORD=Admin1234!

# ── Usuarios de demostración ───────────────────────
# Se crean automáticamente en el primer arranque (centro "IES Demo")
# Ponlo en false para desactivarlos en producción
SEED_DEMO=true
#
# Credenciales demo (cambiables desde el panel de administración):
#   admin_centro       → director@demo.es   / Director1234!
#   coordinador_calidad→ calidad@demo.es    / Calidad1234!
#   docente            → docente@demo.es    / Docente1234!
#   invitado           → invitado@demo.es   / Invitado1234!

# ── Claude API (Módulo 4) ─────────────────────────
ANTHROPIC_API_KEY=
# Modelo Claude a usar (por defecto claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# ── CORS (origen permitido) ───────────────────────
CORS_ORIGIN=http://localhost
